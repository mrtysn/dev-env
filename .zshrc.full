# echo "($(date +"%Y-%m-%d, %H:%M:%S")) Loading .zshrc"

# ─── Instant Prompt ─────────────────────────────────────────────────────────────
# Must stay at the top. Any code requiring console input goes ABOVE this block.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# ─── Oh My Zsh Configuration ────────────────────────────────────────────────────
export ZSH="$HOME/.oh-my-zsh"

# https://stackoverflow.com/questions/62931101/i-have-multiple-files-of-zcompdump-why-do-i-have-multiple-files-of-these
export ZSH_COMPDUMP="$ZSH/cache/.zcompdump-$HOST"

# Case-sensitive completion must be off. _ and - will be interchangeable.
HYPHEN_INSENSITIVE="true"

# zstyle ':omz:update' mode disabled  # disable automatic updates
# zstyle ':omz:update' mode auto      # update automatically without asking
zstyle ':omz:update' mode reminder    # just remind me to update when it's time
zstyle ':omz:update' frequency 13

COMPLETION_WAITING_DOTS="true"

# Uncomment to disable marking untracked files as dirty (faster for large repos)
# DISABLE_UNTRACKED_FILES_DIRTY="true"

# "mm/dd/yyyy"|"dd.mm.yyyy"|"yyyy-mm-dd" or strftime format
HIST_STAMPS="yyyy-mm-dd"

# Conditional plugin loading: minimal set for Claude Code
if [[ -z "$CLAUDECODE" ]]; then
  # Full plugin list for normal shell
  plugins=(
    fzf-tab gitfast ls cd-ls copypath copybuffer command-not-found
    autoupdate macos zsh-autosuggestions fast-syntax-highlighting asdf
    alias-tips git-it-on catimg isodate colored-man-pages
    dircycle auto-notify autoswitch_virtualenv
  )
  # temporarily removed: safe-paste
  # replaced: git with gitfast
else
  # Essential plugins for Claude Code
  plugins=(gitfast command-not-found asdf)
fi

ZSH_THEME=""  # using homebrew p10k, not OMZ theme

# ─── Environment (needed by PATH) ───────────────────────────────────────────────
export PNPM_HOME="$HOME/Library/pnpm"              # pnpm
export ANDROID_HOME="$HOME/Library/Android/sdk"   # android
export OLLAMA_ORIGINS="*"

# Perl local::lib
export PERL5LIB="$HOME/perl5/lib/perl5${PERL5LIB:+:$PERL5LIB}"
export PERL_LOCAL_LIB_ROOT="$HOME/perl5${PERL_LOCAL_LIB_ROOT:+:$PERL_LOCAL_LIB_ROOT}"
export PERL_MB_OPT="--install_base \"$HOME/perl5\""
export PERL_MM_OPT="INSTALL_BASE=$HOME/perl5"

# ─── PATH ───────────────────────────────────────────────────────────────────────
# Deduplicate PATH entries automatically
typeset -U PATH path

# Go environment (sets GOBIN, etc.)
[[ -f "$HOME/.asdf/plugins/golang/set-env.zsh" ]] && source "$HOME/.asdf/plugins/golang/set-env.zsh"

# Dotnet root for tooling (avoid "." / empty)
DOTNET_ROOT=""
if command -v asdf >/dev/null 2>&1; then
  dotnet_path="$(asdf which dotnet 2>/dev/null)" || dotnet_path=""
  [[ -n "$dotnet_path" ]] && export DOTNET_ROOT="${dotnet_path:h}"   # :h = dirname in zsh
fi

# Only include optional paths if they're non-empty
path=(
  "/opt/homebrew/opt/coreutils/libexec/gnubin"                # gnubin
  "$HOME/.asdf/shims"                                         # asdf
  "$HOME/.dotnet/tools"                                       # dotnet tools
  ${GOBIN:+"$GOBIN"}                                          # go
  ${PNPM_HOME:+"$PNPM_HOME"}                                  # pnpm
  "$HOME/.cache/lm-studio/bin"                                # lm studio cli
  ${ANDROID_HOME:+"$ANDROID_HOME/platform-tools"}             # android
  "$HOME/perl5/bin"                                           # perl
  ${DOTNET_ROOT:+"$DOTNET_ROOT"}                              # dotnet
  "$HOME/bin"
  "$HOME/.local/bin"
  "/usr/local/bin"
  $path
)

# Regenerate asdf shims (set ASDF_RESHIM_ON_START=1 to enable, for A/B testing)
if command -v asdf >/dev/null 2>&1; then
  [[ -n "$ASDF_RESHIM_ON_START" ]] && asdf reshim
fi

# ─── Source Oh My Zsh ───────────────────────────────────────────────────────────
# compinit is inside this script
source "$ZSH/oh-my-zsh.sh"

# ─── Environment (post-OMZ) ─────────────────────────────────────────────────────
unalias _ 2>/dev/null  # OMZ sets _='sudo'; prefer explicit sudo
# Preferred editor for local and remote sessions
if [[ -n $SSH_CONNECTION ]]; then
  export EDITOR='nano'
else
  export EDITOR='code --wait'
fi

# history size fix
export HISTSIZE=99999
export SAVEHIST=$HISTSIZE

# ─── Tool Initialization ────────────────────────────────────────────────────────
# Powerlevel10k theme
source /opt/homebrew/share/powerlevel10k/powerlevel10k.zsh-theme

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ -f "$HOME/.p10k.zsh" ]] && source "$HOME/.p10k.zsh"

# https://github.com/junegunn/fzf?tab=readme-ov-file#setting-up-shell-integration
command -v fzf >/dev/null 2>&1 && source <(fzf --zsh)

# keep at bottom - https://github.com/romkatv/powerlevel10k/issues/1554
unset ZSH_AUTOSUGGEST_USE_ASYNC

# ─── Functions ──────────────────────────────────────────────────────────────────
# list preferred Wi-Fi networks
function get_wifi_networks() {
  local wifi_networks
  wifi_networks=$(networksetup -listpreferredwirelessnetworks en0) || {
    echo "Failed to retrieve Wi-Fi network list."
    return 1
  }
  echo "$wifi_networks" | sed -e 's/^ *//'
}

# send macos notification if prompted for assword
function notify_on_password_prompt() {
  local cmd="${1//\"/\\\"}"
  if [[ "$cmd" =~ "assword" ]]; then
    osascript -e "display notification \"cmd: $cmd\" with title \"password needed\""
  fi
}

# benchmark zshrc load time
# usage: zshrc_bench [-v] [runs] [warmup] [file]
# examples:
#   zshrc_bench              # 10 runs, 1 warmup
#   zshrc_bench 30           # 30 runs
#   zshrc_bench 30 3         # 30 runs, 3 warmup
#   zshrc_bench -v 20 2      # verbose per-run output
#   zshrc_bench 20 2 ~/.zshrc.new   # explicit file
# A/B test asdf reshim:
#   zshrc_bench 20 2
#   ASDF_RESHIM_ON_START=1 zshrc_bench 20 2
function zshrc_bench() {
  emulate -L zsh
  setopt localoptions no_aliases pipefail

  local verbose=0
  if [[ "$1" == "-v" ]]; then
    verbose=1
    shift
  fi

  local runs=${1:-10}
  local warmup=${2:-1}
  local file=${3:-$HOME/.zshrc}

  if (( runs < 1 || warmup < 0 || warmup >= runs )); then
    echo "usage: zshrc_bench [-v] [runs>=1] [warmup>=0<runs] [file]"
    return 2
  fi
  [[ -f "$file" ]] || { echo "file not found: $file"; return 2; }

  local -a times
  local i out ms rc

  local cmd='
    zmodload zsh/datetime
    t0=$EPOCHREALTIME
    source "$ZSHRC_BENCH_FILE" >/dev/null 2>&1
    rc=$?
    t1=$EPOCHREALTIME
    printf "%.0f %d\n" $(( (t1 - t0) * 1000.0 )) $rc
  '

  # warmup (ignored)
  for (( i = 1; i <= warmup; i++ )); do
    ZSHRC_BENCH_FILE="$file" zsh -i -f -c "$cmd" >/dev/null
  done

  # measured runs
  for (( i = 1; i <= runs; i++ )); do
    out=$(ZSHRC_BENCH_FILE="$file" zsh -i -f -c "$cmd")
    ms=${out%% *}
    rc=${out##* }
    times+=("$ms")

    if (( verbose )); then
      printf "run %2d: %4d ms  rc=%d\n" $i $ms $rc
    fi

    if (( rc != 0 )); then
      printf "warning: source returned rc=%d on run %d\n" $rc $i >&2
    fi
  done

  # stats
  local -a sorted
  sorted=("${(@on)times}")
  local sum=0
  for ms in "${times[@]}"; do (( sum += ms )); done

  local n=${#times}
  local min=${sorted[1]}
  local max=${sorted[-1]}
  local avg=$(( sum / n ))

  local median
  if (( n % 2 == 1 )); then
    median=${sorted[$(( (n+1)/2 ))]}
  else
    median=$(( (sorted[n/2] + sorted[n/2+1]) / 2 ))
  fi

  local p95_idx=$(( (95*n + 99) / 100 ))
  local p95=${sorted[$p95_idx]}

  echo "zshrc_bench: $file  runs=$n  warmup=$warmup  (ms)"
  echo "min=$min  median=$median  avg=$avg  p95=$p95  max=$max"
}

# jump to nth most recent aw worktree
# usage: awcd [n|list]
awcd() {
  case "$1" in
    list) aw list-numbered ;;
    *)
      if aw go "$1" && [[ -f /tmp/aw_go && -O /tmp/aw_go && ! -L /tmp/aw_go ]] && source /tmp/aw_go; then
        [[ -n "$_TAB_NAVY" ]] && iterm_tab_color ${=_TAB_NAVY}
      fi
      ;;
  esac
}

# ─── Aliases: Navigation ────────────────────────────────────────────────────────
alias dl="cd $HOME/Downloads"
alias dt="cd $HOME/Desktop"
alias dv="cd $HOME/dev"

# ─── Aliases: Machine-Specific (mert-cypher-m3max) ──────────────────────────────
if [[ "$(hostname -s)" == "mert-cypher-m3max" ]]; then
  # Tab colors (Flat UI Spanish palette) - "R G B" format
  _TAB_BLUE="52 172 224"      # #34ace0 Summer Sky - cbc
  _TAB_NAVY="30 80 140"       # #1e508c - awcd
  _TAB_PURPLE="71 71 135"     # #474787 Lucky Point - claudep
  _TAB_YELLOW="255 177 66"    # #ffb142 Mandarin Sorbet - cad
  _TAB_TEAL="33 140 116"      # #218c74 Palm Springs Splash - mow
  _TAB_RED="179 57 57"        # #b33939 - redis
  _TAB_GREEN="51 217 178"     # #33d9b2 Aurora Green - bm
  _TAB_ORANGE="255 121 63"    # #ff793f Synthetic Pumpkin - cs

  # Claude config dirs
  _CLAUDE_DIR="$HOME/.claude"
  _CLAUDE_PERSONAL_DIR="$HOME/.claude-personal"

  # Claude-in-Chrome: reroute the browser Claude opens to a per-install Chrome profile.
  # A PATH shim intercepts `open -a "Google Chrome" https://clau.de/chrome/...` and adds
  # --profile-directory (mapping lives in the shim; override via CLAUDE_CHROME_PROFILE).
  _CLAUDE_OPEN_SHIM_DIR="$HOME/.local/share/claude-open-shim"
  claude() {
    PATH="$_CLAUDE_OPEN_SHIM_DIR:$PATH" command claude "$@"
  }

  # Codex compatibility for shared Claude-oriented hook configs
  codex() {
    CLAUDE_PROJECT_DIR="${CLAUDE_PROJECT_DIR:-$PWD}" command codex "$@"
  }

  # ── Project alias generators ──────────────────────────────────────────────
  # _proj NAME COLOR DIR  ->  NAME (cd) · NAMEc (claude) · NAMEo (opencode) · NAMEt (tmux)
  _proj() {
    alias "$1=iterm_tab_color $2 && cd $3"
    alias "${1}c=iterm_tab_color $2 && cd $3 && claude"
    alias "${1}o=iterm_tab_color $2 && cd $3 && opencode"
    alias "${1}t=tmux_opencode $1 $3"
  }
  # _combo NAME COLOR DIR ADD-DIRS...  ->  cd $DIR && claude --add-dir <each>
  _combo() {
    local n=$1 c=$2 d=$3; shift 3; local a=""
    for x in "$@"; do a+=" --add-dir $x"; done
    alias "$n=iterm_tab_color $c && cd $d && claude$a"
  }

  # Projects (add a repo = one line)
  _proj cbc "$_TAB_BLUE"   "$HOME/dev/cypher-backend-core"
  _proj cad "$_TAB_YELLOW" "$HOME/dev/cypher-admin-dashboard"
  _proj mow "$_TAB_TEAL"   "$HOME/dev/merge-of-wonders"
  _proj bm  "$_TAB_GREEN"  "$HOME/dev/backend-multi"
  _proj cs  "$_TAB_ORANGE" "$HOME/dev/cannon-smash"

  # Cross-repo combos (open one repo with others added to the session)
  _combo cbccad    "$_TAB_BLUE"   "$HOME/dev/cypher-backend-core"    "$HOME/dev/cypher-admin-dashboard"
  _combo cadcbc    "$_TAB_YELLOW" "$HOME/dev/cypher-admin-dashboard" "$HOME/dev/cypher-backend-core"
  _combo mowcbc    "$_TAB_TEAL"   "$HOME/dev/merge-of-wonders"       "$HOME/dev/cypher-backend-core"
  _combo cbcmow    "$_TAB_BLUE"   "$HOME/dev/cypher-backend-core"    "$HOME/dev/merge-of-wonders"
  _combo cbccadmow "$_TAB_BLUE"   "$HOME/dev/cypher-backend-core"    "$HOME/dev/cypher-admin-dashboard" "$HOME/dev/merge-of-wonders"
  _combo bmcbc     "$_TAB_GREEN"  "$HOME/dev/backend-multi"          "$HOME/dev/cypher-backend-core"
  _combo csbm      "$_TAB_ORANGE" "$HOME/dev/cannon-smash"           "$HOME/dev/backend-multi"

  # Personal / non-uniform shortcuts (different claude config dir)
  alias oj="iterm_tab_color $_TAB_PURPLE && cd \$HOME/dev/personal/godot/oj"
  alias ojc="iterm_tab_color $_TAB_PURPLE && cd \$HOME/dev/personal/godot/oj && CLAUDE_CONFIG_DIR=$_CLAUDE_PERSONAL_DIR claude"
  alias claudep="iterm_tab_color $_TAB_PURPLE && cd \$HOME/dev/personal && CLAUDE_CONFIG_DIR=$_CLAUDE_PERSONAL_DIR claude"
  alias claudepany="iterm_tab_color $_TAB_PURPLE && CLAUDE_CONFIG_DIR=$_CLAUDE_PERSONAL_DIR claude"

  # Deployment shortcuts (pre-types the command, ready to edit/run)
  alias cbcdeploy="iterm_tab_color $_TAB_BLUE && iterm_tab_title '🚀 cbc deploy' && cd \$HOME/dev/cypher-backend-core && print -z './deployment_manager.sh -e '"
  alias caddeploy="iterm_tab_color $_TAB_YELLOW && iterm_tab_title '🚀 cad deploy' && cd \$HOME/dev/cypher-admin-dashboard && print -z './deployment_script_admin_dashboard.sh --'"

  # Service shortcuts
  alias redisstart="iterm_tab_color $_TAB_RED && iterm_tab_title '📒 redis-server' && redis-server"

  # tmux session listing
  alias tls="tmux ls 2>/dev/null || echo 'no live tmux sessions'"
  alias tlw="tmux list-windows -a -F '#{session_name}  #{window_index}:#{window_name}#{?window_active, *,}' 2>/dev/null || echo 'no live tmux sessions'"

  # Peon-ping mute/unmute (all config dirs)
  alias peon-ping-mute="touch \$HOME/.openpeon/.paused $_CLAUDE_DIR/hooks/peon-ping/.paused $_CLAUDE_PERSONAL_DIR/hooks/peon-ping/.paused 2>/dev/null && echo 'peon-ping: muted'"
  alias peon-ping-unmute="rm -f \$HOME/.openpeon/.paused $_CLAUDE_DIR/hooks/peon-ping/.paused $_CLAUDE_PERSONAL_DIR/hooks/peon-ping/.paused 2>/dev/null && echo 'peon-ping: unmuted'"
fi

# ─── Aliases: Git ───────────────────────────────────────────────────────────────
# fancy git log
alias gitlog="git log --graph --format=format:'%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %C(white)%an%C(reset)%C(bold yellow)%d%C(reset) %C(dim white)- %s%C(reset)' --all"

# https://github.com/peterhurford/git-it-on.zsh
alias gitito="gitit branch master"

# ─── Aliases: Utilities ─────────────────────────────────────────────────────────
alias history="history 1"           # history size fix
alias python='python3'
alias bu='brew update && brew upgrade'
alias zshconfig="subl $HOME/.zshrc"
alias wifi-list='get_wifi_networks'

# show all files in a tree structure (works with ls zsh plugin)
alias lta="lt -a"

# show all files whose names begin with '.' except . and ..
alias lsa="ls -A"

# tailscale cli
alias tailscale="/Applications/Tailscale.app/Contents/MacOS/Tailscale"

# ─── iTerm2 Helpers ──────────────────────────────────────────────────────────
# Set iTerm2 tab color (RGB 0-255)
# Usage: iterm_tab_color 80 120 200
function iterm_tab_color() {
  [[ "$TERM_PROGRAM" == "iTerm.app" ]] || return 0
  printf "\e]6;1;bg;red;brightness;%d\a\e]6;1;bg;green;brightness;%d\a\e]6;1;bg;blue;brightness;%d\a" "$1" "$2" "$3" 2>/dev/null
  return 0
}

# Set iTerm2 tab title (disables oh-my-zsh auto title for this session)
# Usage: iterm_tab_title "My Tab"
function iterm_tab_title() {
  [[ "$TERM_PROGRAM" == "iTerm.app" ]] || return 0
  DISABLE_AUTO_TITLE=true
  print -Pn "\e]1;$1\a" 2>/dev/null
  return 0
}

# Reset iTerm2 tab color to default
function iterm_tab_color_reset() {
  [[ "$TERM_PROGRAM" == "iTerm.app" ]] || return 0
  echo -e "\033]6;1;bg;*;default\007" 2>/dev/null
  return 0
}

# fzf picker over a project's opencode tmux sessions, with a live screen preview.
# Row: name · attached-dot · window count · last activity. Preview = the session's screen.
# Enter: attach/create   Ctrl-X: kill highlighted session   Esc: cancel.
# Usage: tmux_opencode <base-name> <project-dir>
function tmux_opencode() {
  local base="$1" d="$2" fmt list out key line choice
  fmt=$'#{session_name}\t#{?session_attached,●, }\t#{session_windows}\t#{t:session_activity}'
  while true; do
    list=$(tmux ls -F "$fmt" 2>/dev/null | awk -F'\t' -v b="$base" '
      $1==b || index($1,b"-")==1 {
        split($4, t, /[ ]+/)                                 # Tue Jun 23 14:42:31 2026
        printf "%s\t%-12s %s %sw  %s %s %s\n", $1, $1, $2, $3, t[2], t[3], substr(t[4],1,5)
      }')
    out=$( { [[ -n "$list" ]] && print -r -- "$list"; print -r -- $'＋ new session\t＋ new session'; } \
           | fzf --delimiter=$'\t' --with-nth=2 --expect=ctrl-x --prompt="$base ▶ " \
                 --height=70% --reverse --header='↵ attach/create   ^X kill   esc cancel' \
                 --preview 'tmux capture-pane -ep -t {1} 2>/dev/null || echo "↳ spawns a fresh opencode session"' \
                 --preview-window='right,55%,wrap' )
    [[ -z "$out" ]] && return                          # Esc = abort
    key="${out%%$'\n'*}"                               # line 1 = pressed key ('' for Enter)
    line="${out#*$'\n'}"                               # line 2 = selected row
    choice="${line%%$'\t'*}"                           # first field = session name
    if [[ "$key" == ctrl-x ]]; then
      [[ "$choice" != '＋ new session' ]] && tmux kill-session -t "$choice" 2>/dev/null
      continue                                         # reopen picker, list refreshed
    fi
    break
  done
  if [[ "$choice" == '＋ new session' ]]; then
    local name="$base" n=2 w
    while tmux has-session -t "$name" 2>/dev/null; do name="$base-$n"; ((n++)); done
    w=$(tmux new-session -d -s "$name" -c "$d" -n '🦙 opencode' -P -F '#{window_id}')
    tmux set-window-option -t "$w" automatic-rename off
    tmux set-window-option -t "$w" allow-rename off
    tmux send-keys -t "$w" 'opencode' C-m
    choice="$name"
  fi
  if [[ -n "$TMUX" ]]; then tmux switch-client -t "$choice"; else tmux attach -t "$choice"; fi
}

# ─── Hooks ──────────────────────────────────────────────────────────────────────
autoload -Uz add-zsh-hook
add-zsh-hook preexec notify_on_password_prompt
